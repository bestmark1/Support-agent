APP_ENV=dev
LOG_LEVEL=INFO

SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fitmentor
KB_API_BASE_URL=http://127.0.0.1:8010

AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=claude-sonnet-4-6
AI_GATEWAY_TIMEOUT_SECONDS=45

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_PATH=/opt/agent/workspace/fitmentor-agent/.secrets/telethon_support.session
TELEGRAM_OWNER_USER_ID=
TELEGRAM_TEST_USER_IDS=
FITMENTOR_INTERNAL_BASE_URL=https://fitmentor-ai.ru
FITMENTOR_SUPPORT_INTERNAL_TOKEN=

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
